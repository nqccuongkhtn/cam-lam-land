# ─── Database (PostGIS) ───────────────────────────────────────────
POSTGRES_USER=camlam
POSTGRES_PASSWORD=camlam_secret_change_me
POSTGRES_DB=camlam_gis
POSTGRES_HOST=postgis
POSTGRES_PORT=5432
# Host port to reach PostGIS from your machine (5433 avoids clashing with a local Postgres on 5432)
POSTGRES_HOST_PORT=5433

# ─── Backend API ──────────────────────────────────────────────────
BACKEND_PORT=4000
JWT_SECRET=please_change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d
# Seed admin account (created on first boot)
ADMIN_EMAIL=admin@camlam.local
ADMIN_PASSWORD=admin12345

# Where uploaded GIS files land (shared volume between backend & worker)
UPLOAD_DIR=/data/uploads

# ─── GIS worker ───────────────────────────────────────────────────
WORKER_POLL_MS=4000
# Auto-import the bundled Cam Lâm demo layers on first boot
SEED_DEMO_DATA=true

# ─── Frontend (Next.js) ───────────────────────────────────────────
# Browser calls the API through the Nginx reverse proxy at /api
NEXT_PUBLIC_API_BASE=/api
# Default map view — Cam Lâm, Khánh Hòa (WGS84 / EPSG:4326)
NEXT_PUBLIC_MAP_CENTER_LNG=109.0917
NEXT_PUBLIC_MAP_CENTER_LAT=12.0771
NEXT_PUBLIC_MAP_ZOOM=12

# ─── Nginx ────────────────────────────────────────────────────────
NGINX_PORT=80

# ─── TỰ HOST RA INTERNET (Cloudflare Tunnel) ──────────────────────
# Domain thật của bạn (cho SEO + link chia sẻ), vd: https://nhadatcamlam.com
NEXT_PUBLIC_SITE_URL=
# Token của Cloudflare Tunnel. Lấy tại: Cloudflare → Zero Trust → Networks → Tunnels
# → Create a tunnel → chọn Docker → copy chuỗi dài đứng sau "--token ...".
# Trong tunnel, thêm Public hostname: <domain của bạn> → Service = HTTP → nginx:80
TUNNEL_TOKEN=

# ─── BẢO MẬT: khi chạy server thật, ĐỔI 3 dòng dưới thành chuỗi mạnh, ngẫu nhiên ──
#   JWT_SECRET (ở trên) = chuỗi dài ngẫu nhiên
#   ADMIN_PASSWORD (ở trên) = mật khẩu admin mạnh
#   POSTGRES_PASSWORD (ở trên) = mật khẩu DB mạnh

# ─── AI ĐỌC ẢNH SỔ ĐỎ / OCR + PUSH + THANH TOÁN ───────────────────
# COPY Y NGUYÊN các giá trị này từ Render (Dashboard → service camlam-api → Environment).
# Bỏ trống dòng nào thì chức năng đó tắt (vẫn chạy web bình thường).
GEMINI_API_KEYS=
GEMINI_MODELS=
GROQ_API_KEY=
OPENROUTER_API_KEY=
OCRSPACE_API_KEY=
SELF_OCR_URL=
SELF_OCR_TOKEN=
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_SUBJECT=
EMAIL_ENABLED=
PAYMENT_WEBHOOK_KEY=
BANK_ID=
BANK_ACCOUNT=
BANK_NAME=
